<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {{.Width}} {{.Height}}" width="{{.Width}}" height="{{.Height}}">
{{- if .Title}}
<title>{{.Title}}</title>
{{- end}}
<defs>
  <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
    <polygon points="0 0, 10 3.5, 0 7" fill="#666"/>
  </marker>
</defs>
<style>
  .node rect { stroke: #999; stroke-width: 1.5; rx: 6; ry: 6; }
  .node text { font-family: sans-serif; font-size: 13px; fill: #333; text-anchor: middle; dominant-baseline: central; }
  .node .balance { font-size: 10px; fill: #666; text-anchor: end; dominant-baseline: auto; }
  .edge path { fill: none; stroke: #666; stroke-width: 1.5; marker-end: url(#arrowhead); }
  .edge text { font-family: sans-serif; font-size: 11px; fill: #555; text-anchor: middle; }
  .legend text { font-family: sans-serif; font-size: 11px; fill: #333; dominant-baseline: central; }
  .legend rect { stroke: #999; stroke-width: 1; rx: 3; ry: 3; }
{{- if .Animate}}
  @keyframes flow {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }
  .edge path { stroke-dasharray: 6 3; animation: flow 1.5s linear infinite; }
{{- end}}
</style>
{{range .Nodes}}
<g class="node" transform="translate({{.X}},{{.Y}})">
  <rect width="{{.W}}" height="{{.H}}" fill="{{.Fill}}"/>
  <text x="{{half .W}}" y="{{half .H}}">{{.Label}}</text>
{{- if .Balance}}
  <text class="balance" x="{{.W | printf "%.0f"}}" y="{{.H | printf "%.0f"}}" dx="-4" dy="-4">{{.Balance}}</text>
{{- end}}
</g>
{{- end}}
{{range .Edges}}
<g class="edge">
  <path d="{{.PathD}}"{{if $.Animate}} style="animation-delay: {{.AnimDelay}}s"{{end}}/>
{{- if .Desc}}
  <text x="{{.DescX}}" y="{{.DescY}}">{{.Desc}}</text>
{{- end}}
  <text x="{{.AmountX}}" y="{{.AmountY}}">{{.Amount}}</text>
</g>
{{- end}}
{{- if .Legend}}
<g class="legend" transform="translate(20,{{.Height | printf "%.0f"}})" dy="-30">
{{- range $i, $e := .Legend}}
  <rect x="{{multiply $i 100}}" y="-30" width="14" height="14" fill="{{$e.Fill}}"/>
  <text x="{{multiply $i 100 | add 18}}" y="-23">{{$e.Label}}</text>
{{- end}}
</g>
{{- end}}
</svg>
